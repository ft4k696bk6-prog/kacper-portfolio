NEXT_PUBLIC_SITE_URL=https://kacper-portfolio.vercel.app

# Contact details revealed only after the human check
CONTACT_TO_EMAIL=
CONTACT_REVEAL_EMAIL=
CONTACT_REVEAL_PHONE=

# Cloudflare Turnstile anti-bot check
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional Google Tag Manager
NEXT_PUBLIC_GTM_ID=

# Optional Google Analytics 4 measurement ID, for example G-XXXXXXXXXX.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Server-only NVIDIA/NIM API for the portfolio AI consultant.
# Do not prefix the key with NEXT_PUBLIC_.
NVIDIA_API_KEY=
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Public GLB path for the Three.js assistant character.
# Defaults to /models/ai-assistant.glb when unset.
NEXT_PUBLIC_AI_ASSISTANT_MODEL_PATH=/models/ai-assistant.glb

# Booking calendar through Cal.com API.
# CAL_API_KEY is server-only. Do not prefix it with NEXT_PUBLIC_.
CAL_API_KEY=
CAL_EVENT_TYPE_ID=

# Fallback if CAL_EVENT_TYPE_ID is not used.
CAL_USERNAME=
CAL_EVENT_TYPE_SLUG=

NEXT_PUBLIC_CALENDAR_TIMEZONE=Europe/Warsaw
