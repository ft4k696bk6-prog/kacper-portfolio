NEXT_PUBLIC_SITE_URL=https://kacper-portfolio.vercel.app

# Contact details revealed only after the human check
CONTACT_TO_EMAIL=
CONTACT_REVEAL_EMAIL=
CONTACT_REVEAL_PHONE=

# Cloudflare Turnstile anti-bot check
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional Google Tag Manager
NEXT_PUBLIC_GTM_ID=

# Booking calendar through Cal.com API.
# CAL_API_KEY is server-only. Do not prefix it with NEXT_PUBLIC_.
CAL_API_KEY=
CAL_EVENT_TYPE_ID=

# Fallback if CAL_EVENT_TYPE_ID is not used.
CAL_USERNAME=
CAL_EVENT_TYPE_SLUG=

NEXT_PUBLIC_CALENDAR_TIMEZONE=Europe/Warsaw
